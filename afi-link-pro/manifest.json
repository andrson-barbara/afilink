{
  "manifest_version": 3,
  "name": "Afi-link Pro: Gerador 1-Click",
  "version": "1.0.0",
  "description": "Automatize a geração de links de afiliados na Amazon e Mercado Livre.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "notifications",
    "identity"
  ],
  "key": "",
  "oauth2": {
    "client_id": "780656617097-qi6cm7tm2oclijcr1jftmvflpvcfhid2.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/userinfo.email"]
  },
  "host_permissions": [
    "*://*.amazon.com/*",
    "*://*.amazon.com.br/*",
    "*://*.mercadolivre.com.br/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.com/*",
        "*://*.amazon.com.br/*",
        "*://*.mercadolivre.com.br/*"
      ],
      "js": ["content_script.js"]
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
